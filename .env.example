# Copy to .env and fill in values.
# ---------------------------------------------------------------------------
# Upstream APIs (register & paste keys)
# ---------------------------------------------------------------------------
# GNews — https://gnews.io/ (100 req/day free) — required for news tools
GNEWS_API_KEY=

# Finnhub — https://finnhub.io/ (optional, PS2 / enrichment)
FINNHUB_API_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key (optional)
ALPHA_VANTAGE_API_KEY=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# MCP on host → your machine: redis://localhost:6379/0 (or cluster URL if you use one).
# docker compose overrides MCP container to redis://redis:6379/0 (Compose Redis is not published to :6379 on the host).
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# MCP server
# ---------------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Public base URL of this MCP server (used in OAuth protected-resource metadata)
MCP_BASE_URL=http://localhost:8000
STREAMABLE_HTTP_PATH=/mcp

# ---------------------------------------------------------------------------
# Auth: keycloak | static (static = JSON map of bearer tokens for dev/tests)
# ---------------------------------------------------------------------------
AUTH_MODE=keycloak
# Example static (single line JSON): {"dev-free":{"client_id":"c","scopes":["market:read","mf:read","news:read","portfolio:read","portfolio:write"],"sub":"u1"}}
STATIC_TOKENS_JSON={}

# Keycloak — UI & token endpoint on host port 8090 (not 8080) to avoid conflicts
KEYCLOAK_ISSUER=http://localhost:8090/realms/stocksonar
# MCP on host: use localhost. MCP in Docker Compose: set to http://keycloak:8080/.../certs
KEYCLOAK_JWKS_URI=http://localhost:8090/realms/stocksonar/protocol/openid-connect/certs
KEYCLOAK_AUTHORIZATION_SERVER=http://localhost:8090/realms/stocksonar
# JWT aud validation (RFC 8707) — Keycloak direct-access tokens usually use "account"
KEYCLOAK_AUDIENCE=account

# Streamable HTTP: JSON responses enable HTTP 429 + Retry-After on tier rate limits
MCP_JSON_RESPONSE=true

# Server-wide GNews calls per calendar day (stay under provider free tier)
GNEWS_DAILY_QUOTA=90

# ---------------------------------------------------------------------------
# Rate limits (requests per hour, sliding window)
# ---------------------------------------------------------------------------
RATE_LIMIT_FREE=30
RATE_LIMIT_PREMIUM=150
RATE_LIMIT_ANALYST=500
