# Static-token auth mode — no Keycloak needed.
# Use with:  docker compose --env-file .env.llm up -d --build mcp-server
# Or:        cp .env.llm .env  (then normal docker compose up)
AUTH_MODE=static

# Tokens: "Bearer <key>" → scopes / identity.
# analyst-token  → all scopes (full access)
# premium-token  → premium scopes
# free-token     → free-tier scopes only
STATIC_TOKENS_JSON={"analyst-token":{"client_id":"llm-client","sub":"llm-analyst","scopes":["market:read","mf:read","news:read","portfolio:read","portfolio:write","watchlist:read","watchlist:write","fundamentals:read","technicals:read","macro:read","portfolio:risk","news:sentiment","filings:read","filings:deep","macro:historical","research:generate"]},"premium-token":{"client_id":"llm-client","sub":"llm-premium","scopes":["market:read","mf:read","news:read","portfolio:read","portfolio:write","watchlist:read","watchlist:write","fundamentals:read","technicals:read","macro:read","portfolio:risk","news:sentiment"]},"free-token":{"client_id":"llm-client","sub":"llm-free","scopes":["market:read","mf:read","news:read","portfolio:read","portfolio:write","watchlist:read","watchlist:write"]}}

REDIS_URL=redis://redis:6379/0
MCP_BASE_URL=http://localhost:8000
KEYCLOAK_AUTHORIZATION_SERVER=http://localhost:8090/realms/stocksonar
